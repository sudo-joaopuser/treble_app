<?xml version="1.0" encoding="utf-8"?>
<PreferenceScreen
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:android="http://schemas.android.com/apk/res/android">

    <PreferenceCategory
        android:title="@string/touch"
        android:layout="@layout/preference_category_custom">
        <SwitchPreference
            android:layout="@layout/preference_switch_custom"
            android:defaultValue="false"
            android:key="nubia_double_tap_to_wake"
            android:title="@string/dt2w"
            app:summary="@string/dt2nubia_summary" />
        <SwitchPreference
            android:layout="@layout/preference_switch_custom"
            android:defaultValue="false"
            android:key="nubia_high_touch_sample_rate"
            android:title="@string/nubiahight_touch"
            app:summary="@string/nubiatouch_summary" />
        <SwitchPreference
            android:layout="@layout/preference_switch_custom"
            android:defaultValue="false"
            android:key="nubia_high_touch_sensitivity"
            android:title="@string/hightouch_gloves"
            app:summary="@string/hightouchsummary" />
    </PreferenceCategory>

    <PreferenceCategory
        android:title="@string/oneplusother"
        android:layout="@layout/preference_category_custom">
        <SwitchPreference
            android:layout="@layout/preference_switch_custom"
            android:defaultValue="false"
            android:key="nubia_touchscreen_game_mode"
            android:title="@string/gamemode_oppo"
            app:summaryOn="@string/nubsumary" />
        <SwitchPreference
            android:layout="@layout/preference_switch_custom"
            android:defaultValue="false"
            android:key="nubia_shoulder_btn"
            android:title="@string/shoulerbuttom"
            app:summary="@string/shoulerbuttom" />
        <SwitchPreference
            android:layout="@layout/preference_switch_custom"
            android:defaultValue="false"
            android:key="nubia_bypass_charger"
            android:title="Enable bypass charger"
            app:summaryOff="Charger -> Battery -> Phone"
            app:summaryOn="Charger->Phone" />
        <ListPreference
            android:layout="@layout/preference_list_custom"
            android:defaultValue="0"
            android:entries="@array/pref_nubia_fan"
            android:entryValues="@array/pref_nubia_fan_values"
            android:key="nubia_fan_speed"
            android:title="FAN speed"
            app:summary="Support smart charging" />
    </PreferenceCategory>

    <PreferenceCategory
        android:title="\nLEDS"
        android:layout="@layout/preference_category_custom">
        <SwitchPreference
            android:layout="@layout/preference_switch_custom"
            android:defaultValue="false"
            android:key="nubia_redmagic_logo_breath"
            android:title="Make Redmagic logo breath" />
        <ListPreference
            android:layout="@layout/preference_list_custom"
            android:defaultValue="-1"
            android:entries="@array/pref_nubia_redmagic_led"
            android:entryValues="@array/pref_nubia_redmagic_led_values"
            android:key="nubia_redmagic_led"
            android:title="REDMAGIC RGB" />
    </PreferenceCategory>

    <PreferenceCategory
        android:title="\nBOOSTS"
        android:layout="@layout/preference_category_custom">
        <SwitchPreference
            android:layout="@layout/preference_switch_custom"
            android:defaultValue="false"
            android:key="nubia_boost_cpu"
            android:title="Boost CPU" />
        <SwitchPreference
            android:layout="@layout/preference_switch_custom"
            android:defaultValue="false"
            android:key="nubia_boost_cache"
            android:title="Boost caches" />
        <SwitchPreference
            android:layout="@layout/preference_switch_custom"
            android:defaultValue="false"
            android:key="nubia_boost_gpu"
            android:title="Boost GPU" />
        <SwitchPreference
            android:layout="@layout/preference_switch_custom"
            android:defaultValue="false"
            android:key="nubia_boost_ufs"
            android:title="Boost UFS"
            app:summaryOn="Increase Read/Write speed" />
    </PreferenceCategory>

</PreferenceScreen>
